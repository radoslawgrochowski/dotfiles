{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "docker",
        "container",
        "run",
        "-i",
        "--rm",
        "--init",
        "--add-host=host.docker.internal:host-gateway",
        "mcr.microsoft.com/playwright/mcp"
      ],
      "enabled": true
    },
    "nixos": {
      "type": "local",
      "command": ["mcp-nixos"],
      "enabled": true
    }
  },
  "permission": {
    "webfetch": "allow",
    "bash": {
      "cat *": "allow",
      "cd *": "allow",
      "find *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git show *": "allow",
      "git status": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "tail *": "allow",
      "wc *": "allow"
    }
  }
}
