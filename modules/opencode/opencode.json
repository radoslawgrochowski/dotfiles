{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "permission": {
    "bash": {
      "jj help": "allow",
      "jj help *": "allow",
      "jj version": "allow",
      "jj root": "allow",
      "jj status": "allow",
      "jj status *": "allow",
      "jj st": "allow",
      "jj st *": "allow",
      "jj log": "allow",
      "jj log *": "allow",
      "jj l": "allow",
      "jj l *": "allow",
      "jj diff": "allow",
      "jj diff *": "allow",
      "jj d": "allow",
      "jj d *": "allow",
      "jj show": "allow",
      "jj show *": "allow",
      "jj file show": "allow",
      "jj file show *": "allow",
      "jj file list": "allow",
      "jj file list *": "allow",
      "jj file annotate": "allow",
      "jj file annotate *": "allow",
      "jj annotate": "allow",
      "jj annotate *": "allow",
      "jj obslog": "allow",
      "jj obslog *": "allow",
      "jj evolog": "allow",
      "jj evolog *": "allow",
      "jj interdiff": "allow",
      "jj interdiff *": "allow",
      "jj branch list": "allow",
      "jj branch list *": "allow",
      "jj bookmark list": "allow",
      "jj bookmark list *": "allow",
      "jj tags": "allow",
      "jj tags *": "allow",
      "jj config list": "allow",
      "jj config list *": "allow",
      "jj config get": "allow",
      "jj config get *": "allow",
      "jj git remote list": "allow",
      "jj git remote list *": "allow",
      "jj workspace list": "allow",
      "jj workspace list *": "allow",
      "jj sparse list": "allow",
      "jj sparse list *": "allow",
      "jj op log": "allow",
      "jj op log *": "allow",
      "gcloud storage ls": "allow",
      "gcloud storage ls *": "allow",
      "gcloud storage cat *": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "*": "ask",
          "jj help": "allow",
          "jj help *": "allow",
          "jj version": "allow",
          "jj root": "allow",
          "jj status": "allow",
          "jj status *": "allow",
          "jj st": "allow",
          "jj st *": "allow",
          "jj log": "allow",
          "jj log *": "allow",
          "jj l": "allow",
          "jj l *": "allow",
          "jj diff": "allow",
          "jj diff *": "allow",
          "jj d": "allow",
          "jj d *": "allow",
          "jj show": "allow",
          "jj show *": "allow",
          "jj file show": "allow",
          "jj file show *": "allow",
          "jj file list": "allow",
          "jj file list *": "allow",
          "jj file annotate": "allow",
          "jj file annotate *": "allow",
          "jj annotate": "allow",
          "jj annotate *": "allow",
          "jj obslog": "allow",
          "jj obslog *": "allow",
          "jj evolog": "allow",
          "jj evolog *": "allow",
          "jj interdiff": "allow",
          "jj interdiff *": "allow",
          "jj branch list": "allow",
          "jj branch list *": "allow",
          "jj bookmark list": "allow",
          "jj bookmark list *": "allow",
          "jj tags": "allow",
          "jj tags *": "allow",
          "jj config list": "allow",
          "jj config list *": "allow",
          "jj config get": "allow",
          "jj config get *": "allow",
          "jj git remote list": "allow",
          "jj git remote list *": "allow",
          "jj workspace list": "allow",
          "jj workspace list *": "allow",
          "jj sparse list": "allow",
          "jj sparse list *": "allow",
          "jj op log": "allow",
          "jj op log *": "allow",
          "gcloud storage ls": "allow",
          "gcloud storage ls *": "allow",
          "gcloud storage cat *": "allow"
        }
      }
    }
  },
  "provider": {
    "openai": {
      "options": {
        "headerTimeout": 120000
      }
    }
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "docker",
        "container",
        "run",
        "-i",
        "--rm",
        "--init",
        "--add-host=host.docker.internal:host-gateway",
        "mcr.microsoft.com/playwright/mcp"
      ],
      "enabled": true
    },
    "nixos": {
      "type": "local",
      "command": ["docker", "run", "--rm", "-i", "ghcr.io/utensils/mcp-nixos"],
      "enabled": true
    }
  }
}
